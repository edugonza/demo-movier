# Google Cloud project (required for Google STT + TTS)
GOOGLE_CLOUD_PROJECT=your-project-id

# GCS bucket used to stage Long Audio API output (required when TTS input exceeds ~5 KB)
GOOGLE_CLOUD_BUCKET=your-bucket-name

# Google application credentials (if not using gcloud auth)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ElevenLabs (optional, only if using --tts elevenlabs)
# ELEVENLABS_API_KEY=your-api-key

# movier refine --backend llm uses Gemini Flash via Vertex AI.
# No extra key needed — it reuses GOOGLE_CLOUD_PROJECT + ADC above.
